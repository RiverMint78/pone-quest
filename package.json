{
  "name": "pone-quest-ui",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "dev:css": "bunx @tailwindcss/cli -i ./ui/src/style.css -o ./ui/static/css/style.css --watch",
    "build:css": "bunx @tailwindcss/cli -i ./ui/src/style.css -o ./ui/static/css/style.css --minify",
    "dev:js": "bun build ./ui/src/app.ts --outfile ./ui/static/js/ui.js --target browser --watch",
    "build:js": "bun build ./ui/src/app.ts --outfile ./ui/static/js/ui.js --target browser --minify",
    "dev": "bun run dev:css & bun run dev:js",
    "build": "bun run build:css && bun run build:js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "htmx.org": "^2.0.0"
  }
}