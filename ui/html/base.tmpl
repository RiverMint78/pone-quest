{{define "base.tmpl"}}
<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PoneQuest</title>
    <link rel="stylesheet" href="/static/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
</head>

<body class="antialiased">
    <main class="max-w-5xl mx-auto px-8 py-24">

        <header class="mb-20 select-none text-left">
            <h1 class="brand-title">
                Pone<span class="brand-quest">Quest</span>
                <span class="brand-dot"></span>
            </h1>
            <div class="h-1 w-20 bg-amber-100 rounded-full mt-2"></div>
        </header>

        <section class="max-w-2xl mb-24">
            <div class="flex items-stretch gap-4 mb-6">
                <div class="relative flex-grow group">
                    <input type="text" name="q" id="search-input"
                        class="w-full px-8 py-5 bg-white rounded-3xl border border-stone-100 text-xl focus:border-amber-200 focus:ring-4 focus:ring-amber-50/50 outline-none transition-all duration-300 shadow-sm group-focus-within:shadow-xl"
                        placeholder="输入内容..." hx-get="/search" hx-trigger="keyup[key=='Enter']"
                        hx-include="#topk-slider" hx-target="#results-grid" hx-indicator="#loading">

                    <div id="loading" class="htmx-indicator absolute right-6 top-1/2 -translate-y-1/2">
                        <div class="h-5 w-5 border-2 border-rose-300 border-t-transparent rounded-full animate-spin">
                        </div>
                    </div>
                </div>

                <button hx-get="/search" hx-include="#search-input, #topk-slider" hx-target="#results-grid"
                    hx-indicator="#loading"
                    class="px-10 py-5 bg-amber-100 hover:bg-amber-200 text-amber-800 rounded-3xl font-bold transition-all active:scale-95 shadow-sm">
                    搜索
                </button>
            </div>

            <div class="flex items-center gap-6 px-4">
                <span class="text-stone-400 text-base uppercase tracking-widest font-bold">Limit</span>
                <input type="range" name="topK" id="topk-slider" min="5" max="50" value="10" style="--val: 11.11%;"
                    class="flex-grow appearance-none bg-transparent cursor-pointer focus:outline-none"
                    oninput="this.nextElementSibling.innerText = this.value; this.style.setProperty('--val', ((this.value - this.min) / (this.max - this.min) * 100) + '%')">
                <span class="text-amber-600 font-mono text-xl w-8">10</span>
            </div>
        </section>

        <div id="results-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-10">
            <div class="col-span-full text-stone-300 text-sm tracking-widest italic">WAITING FOR INPUT...</div>
        </div>
    </main>
</body>

</html>
{{end}}