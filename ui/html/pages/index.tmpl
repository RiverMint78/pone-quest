{{define "content"}}
<div class="flex flex-col md:flex-row min-h-screen bg-stone-50/30">

    <aside id="sidebar"
        class="relative flex-shrink-0 bg-white border-r border-stone-100 p-6 flex flex-col sticky top-0 md:h-screen md:overflow-y-auto z-10 shadow-sm min-w-[320px] w-80 max-w-2xl">

        <header class="mb-8 flex justify-between items-center select-none">
            <div>
                <h1 class="brand-title text-4xl">Pone<span class="brand-quest">Quest</span><span
                        class="brand-dot"></span></h1>
                <div class="h-1 w-12 bg-amber-100 mt-1"></div>
            </div>
        </header>

        <div class="space-y-6">
            <button id="toggle-search"
                class="w-full flex items-center justify-center gap-2 py-2 text-xs font-medium text-stone-500 hover:bg-stone-50 transition-colors border border-stone-100 rounded-md md:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" class="lucide-chevrons-up-down">
                    <path d="m7 15 5 5 5-5"></path>
                    <path d="m7 9 5-5 5 5"></path>
                </svg>
                展开/收缩查询框
            </button>

            <div id="search-content" class="space-y-6">
                <div class="space-y-2">
                    <div class="flex justify-between items-center">
                        <label class="text-sm font-bold text-stone-700">查询内容</label>
                        <button
                            onclick="document.getElementById('search-input').value=''; document.getElementById('search-input').focus();"
                            class="text-sm text-stone-400 hover:text-amber-600 uppercase tracking-tighter transition-colors">
                            [清空]
                        </button>
                    </div>
                    <textarea name="q" id="search-input" rows="2"
                        class="w-full px-4 py-3 bg-stone-50 border border-stone-200 text-sm focus:border-amber-400 focus:bg-white outline-none transition-colors resize-y min-h-[60px]"
                        placeholder="想找什么样的图？" hx-get="/search" hx-trigger="keyup[key=='Enter']" hx-include="#topk-real"
                        hx-target="#results-grid" hx-indicator="#loading"></textarea>
                </div>

                <div class="flex flex-col gap-2">
                    <div class="flex justify-between items-end">
                        <label class="text-sm font-bold text-stone-700">图片数量</label>
                        <span id="topk-display"
                            class="text-[11px] font-mono font-black text-amber-600 bg-amber-50 px-2 py-0.5 border border-amber-200/50">10</span>
                    </div>

                    <div class="relative h-6 flex items-center group">
                        <div class="absolute w-full h-1 bg-stone-100 rounded-full"></div>
                        <div id="slider-progress"
                            class="absolute h-1 bg-amber-400 rounded-full transition-all duration-200"
                            style="width: 33%;"></div>

                        <div class="absolute w-full flex justify-between px-0.5 pointer-events-none">
                            <div class="w-1 h-1 rounded-full bg-stone-300"></div>
                            <div class="w-1 h-1 rounded-full bg-stone-300"></div>
                            <div class="w-1 h-1 rounded-full bg-stone-300"></div>
                            <div class="w-1 h-1 rounded-full bg-stone-300"></div>
                        </div>

                        <input type="range" min="0" max="3" value="1" id="topk-slider"
                            class="absolute w-full h-full appearance-none bg-transparent cursor-pointer z-10 outline-none"
                            hx-get="/search" hx-include="#search-input, #topk-real" hx-target="#results-grid"
                            hx-trigger="change delay:200ms" hx-indicator="#loading">
                    </div>

                    <input type="hidden" name="topK" id="topk-real" value="10">
                </div>

                <button hx-get="/search" hx-include="#search-input, #topk-real" hx-target="#results-grid"
                    hx-indicator="#loading"
                    class="w-full py-3 bg-stone-800 hover:bg-black text-white text-sm font-bold transition-all shadow-md active:scale-[0.98]">
                    检索
                </button>
            </div>
        </div>

        <div class="mt-auto pt-8 border-t border-stone-50 flex flex-col gap-3">
            <div class="text-[10px] text-stone-300 uppercase tracking-widest text-center">Built for Ponies</div>
        </div>

        <div id="drag-handle"
            class="absolute right-0 top-0 w-1.5 h-full cursor-col-resize group flex items-center justify-center z-20 hover:bg-amber-400/20 transition-colors">
            <div class="w-[1px] h-6 bg-stone-200 group-hover:bg-amber-400"></div>
        </div>
    </aside>

    <main class="flex-grow p-4 md:p-8 w-full overflow-hidden">
        <div id="loading" class="htmx-indicator fixed top-4 right-4 z-50">
            <div class="h-5 w-5 bg-amber-400 animate-loading-square shadow-md"></div>
        </div>
        <div id="results-grid" class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4">
            <div class="break-inside-avoid text-stone-300 text-xs tracking-widest uppercase py-10">Quest log is empty...
            </div>
        </div>
    </main>
</div>
{{end}}