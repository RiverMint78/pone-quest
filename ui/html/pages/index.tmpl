{{define "content"}}
<main class="max-w-7xl mx-auto px-8 py-16">
    <header class="mb-16 select-none text-left">
        <h1 class="brand-title">
            Pone<span class="brand-quest">Quest</span>
            <span class="brand-dot"></span>
        </h1>
        <div class="h-1.5 w-20 bg-amber-100 mt-2"></div>
    </header>

    <section class="max-w-2xl mb-20">
        <div class="flex items-stretch gap-0 mb-6">
            <div class="relative flex-grow group">
                <label for="search-input" class="sr-only">搜索图片</label>
                <input type="text" name="q" id="search-input" maxlength="200"
                    class="w-full px-8 py-5 bg-white border border-stone-200 text-xl focus:border-amber-400 outline-none shadow-sm transition-colors"
                    placeholder="输入搜索内容..." hx-get="/search" hx-trigger="keyup[key=='Enter']" hx-include="#topk-slider"
                    hx-target="#results-grid" hx-indicator="#loading">

                <div id="loading" class="htmx-indicator absolute right-6 top-1/2 -translate-y-1/2">
                    <div class="h-5 w-5 bg-amber-400 animate-loading-square shadow-sm"></div>
                </div>
            </div>

            <button hx-get="/search" hx-include="#search-input, #topk-slider" hx-target="#results-grid"
                hx-indicator="#loading" hx-disabled-elt="this"
                class="px-10 py-5 bg-amber-100 hover:bg-amber-200 text-amber-900 font-bold active:bg-amber-300 transition-colors disabled:opacity-50">
                搜索
            </button>
        </div>

        <div class="flex items-center gap-6 px-4">
            <span class="text-stone-400 text-sm uppercase tracking-widest font-bold">Limit</span>

            <input type="range" id="topk-slider-ui" min="0" max="3" value="1" style="--val: 33.33%;" aria-label="结果数量"
                class="flex-grow appearance-none bg-transparent cursor-pointer outline-none" oninput="
                    const vals = [5, 10, 25, 50];
                    const realVal = vals[this.value];
                    document.getElementById('topk-real').value = realVal;
                    document.getElementById('topk-display').innerText = realVal;
                    this.style.setProperty('--val', (this.value / 3 * 100) + '%');
                ">

            <input type="hidden" name="topK" id="topk-real" value="10">

            <span id="topk-display" class="text-amber-600 font-mono text-xl font-bold w-12">10</span>
        </div>
    </section>

    <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <div class="col-span-full text-stone-300 text-sm tracking-widest italic uppercase">Waiting for quest...</div>
    </div>
</main>
{{end}}