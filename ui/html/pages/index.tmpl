{{define "content"}}
{{template "index.layout" .}}
{{end}}

{{define "index.layout"}}
<div class="flex flex-col md:flex-row min-h-screen bg-cream-bg">
    {{template "index.sidebar" .}}
    {{template "index.main" .}}
    <div id="episode-viewer"></div>
</div>
{{end}}

{{define "index.sidebar"}}
<aside id="sidebar"
    class="relative flex-shrink-0 bg-white border-r border-stone-100 p-6 flex flex-col sticky top-0 md:h-screen md:overflow-y-auto z-10 shadow-sm w-full min-w-0 md:min-w-[320px] md:w-80 md:max-w-2xl">
    {{template "index.sidebar-brand" .}}

    <div class="space-y-6">
        {{template "index.search-panel" .}}
        {{template "index.search-toggle" .}}
    </div>

    {{template "index.sidebar-meta" .}}
    {{template "index.drag-handle" .}}
</aside>
{{end}}

{{define "index.sidebar-brand"}}
<header id="sidebar-brand" class="mb-8 flex justify-between items-center select-none">
    <div>
        <h1 class="brand-title text-4xl">Pone<span class="brand-quest">Quest</span></h1>
        <div class="h-1 w-12 bg-stone-200 mt-1"></div>
    </div>
    <button id="theme-toggle" type="button"
        class="inline-flex h-7 w-7 items-center justify-center text-stone-400 hover:text-stone-700 border border-transparent hover:border-stone-200 hover:bg-stone-50 transition-colors"
        aria-label="切换日夜模式" title="切换日夜模式">
        <span id="theme-toggle-icon" aria-hidden="true">◐</span>
    </button>
</header>
{{end}}

{{define "index.search-panel"}}
{{$searchEndpoint := "/search"}}
{{$resultsTarget := "#results-grid"}}
{{$loadingIndicator := "#loading"}}
<div id="search-content" class="space-y-6">
    <form id="search-form" class="space-y-2" action="{{$searchEndpoint}}" method="get" hx-get="{{$searchEndpoint}}" hx-trigger="submit, keydown[key=='Enter'&&ctrlKey] from:#search-input" hx-include="#search-input" hx-target="{{$resultsTarget}}" hx-indicator="{{$loadingIndicator}}" hx-push-url="true">
        <div class="flex justify-between items-center">
            <label class="text-sm font-bold text-stone-700">语义检索</label>
            <button id="clear-search"
                class="text-sm text-stone-400 hover:text-brand-accent uppercase tracking-tighter transition-colors">
                [清空]
            </button>
        </div>
        <textarea name="q" id="search-input" rows="2"
            class="w-full px-4 py-3 bg-stone-50 border border-stone-200 text-sm focus:border-brand-accent focus:bg-white outline-none transition-colors resize-y min-h-[60px] text-text-main"
            placeholder="Manehattan 如此辉煌的原因……">{{.Query}}</textarea>
        <div class="flex items-center justify-between gap-2">
            <span class="text-[11px] text-stone-400">输入中/英自然语言描述（英文专有名词）</span>
            <span id="search-char-count" class="text-[11px] font-mono text-stone-400">0/500</span>
        </div>
    </form>

    <button id="search-submit" type="submit" form="search-form"
        class="w-full py-3 bg-text-main hover:bg-black text-cream-bg text-sm font-bold transition-all shadow-md active:scale-[0.98]">
        检索
    </button>
</div>
{{end}}

{{define "index.search-toggle"}}
<button id="toggle-search"
    class="w-full flex items-center justify-center gap-2 py-2 text-xs font-medium text-stone-500 hover:bg-stone-50 transition-colors border border-stone-100 rounded-md md:hidden">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" class="lucide-chevrons-up-down">
        <path d="m7 15 5 5 5-5"></path>
        <path d="m7 9 5-5 5 5"></path>
    </svg>
    展开/折叠查询框
</button>
{{end}}

{{define "index.sidebar-meta"}}
<div id="sidebar-meta" class="mt-auto pt-8 border-t border-stone-50 flex flex-col gap-4">
    <div class="flex items-center justify-center gap-2">
        <a href="https://github.com/RiverMint78/pone-quest" target="_blank" rel="noopener noreferrer"
            class="inline-flex h-6 w-6 items-center justify-center text-stone-400 hover:text-stone-700 transition-colors"
            title="GitHub Repository" aria-label="GitHub Repository">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
        </a>
    </div>
    <div class="text-[12px] text-stone-400 text-center leading-tight">Powered by <a href="https://go.dev" target="_blank"
            rel="noopener noreferrer" class="font-semibold hover:underline" style="color: #00ADD8;">Go</a></div>
</div>
{{end}}

{{define "index.drag-handle"}}
<div id="drag-handle"
    class="absolute right-0 top-0 w-1.5 h-full cursor-col-resize group flex items-center justify-center z-20 hover:bg-stone-100 transition-colors">
    <div class="w-[1px] h-6 bg-stone-200 group-hover:bg-brand-accent"></div>
</div>
{{end}}

{{define "index.main"}}
<main class="flex-grow p-4 md:p-8 w-full overflow-hidden">
    {{template "index.loading-indicator" .}}
    {{template "index.episode-loading-indicator" .}}
    <div id="results-grid" class="grid items-start grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {{template "results.tmpl" .}}
    </div>
</main>
{{end}}

{{define "index.loading-indicator"}}
<div id="loading" class="htmx-indicator fixed top-4 right-4 z-50">
    <div class="h-5 w-5 bg-brand-accent animate-loading-square shadow-md"></div>
</div>
{{end}}

{{define "index.episode-loading-indicator"}}
<div id="episode-loading" class="htmx-indicator fixed inset-0 flex items-center justify-center z-50 bg-black/20">
    <div class="flex flex-col items-center gap-3 bg-cream-bg p-8 rounded-lg shadow-lg">
        <div class="relative w-12 h-12">
            <svg class="w-full h-full animate-spin-ring" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="#e7e5e4" stroke-width="2"></circle>
                <path d="M 12 2 A 10 10 0 0 1 22 12" style="stroke: var(--color-brand-accent);" stroke-width="2"
                    stroke-linecap="round"></path>
            </svg>
        </div>
        <p class="text-sm font-medium text-text-main">加载中...</p>
    </div>
</div>
{{end}}