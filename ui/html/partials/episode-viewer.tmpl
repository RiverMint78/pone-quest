{{define "episode-viewer.tmpl"}}
<div class="episode-modal fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true"
    aria-label="剧集全文台词查看">
    <div class="episode-modal__overlay absolute inset-0 bg-stone-900/50" data-episode-close="true"></div>

    <section class="relative z-10 w-full max-w-4xl max-h-[90vh] overflow-hidden bg-white border border-stone-200 shadow-2xl">
        <header class="flex items-start justify-between gap-4 border-b border-stone-100 px-4 py-3">
            <div class="min-w-0">
                <p class="text-[10px] uppercase tracking-widest text-stone-400">
                    {{if .EpisodeCode}}{{.EpisodeCode}}{{else}}Episode {{.EpisodeTitle}}{{end}}
                </p>
                <h2 class="text-base font-semibold text-stone-800 break-words">{{.EpisodeTitle}}</h2>
            </div>
            <button type="button" class="h-8 w-8 border border-stone-200 text-stone-500 hover:text-accent hover:border-accent"
                data-episode-close="true" aria-label="关闭">
                ×
            </button>
        </header>

        <div class="episode-modal__body overflow-y-auto max-h-[calc(90vh-68px)] px-4 py-3">
            {{range .Lines}}
            <article
                class="episode-line border border-transparent px-3 py-2 mb-2 bg-white {{if .Highlighted}}episode-line--highlight{{end}}"
                {{if .Highlighted}}id="episode-highlight"{{end}}>
                <p class="text-[11px] text-stone-400 mb-1">#{{.SeqInEpisode}}</p>
                <p class="text-base text-stone-700 leading-snug {{if .Highlighted}}font-semibold{{end}}">{{.Text}}</p>
                {{if .Character}}
                <p class="mt-1 text-xs font-semibold {{.CharacterCSS}}">{{.Character}}</p>
                {{end}}
            </article>
            {{end}}
        </div>
    </section>
</div>
{{end}}
