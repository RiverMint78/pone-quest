{{define "episode-viewer.tmpl"}}
{{template "episode-viewer.modal" .}}
{{end}}

{{define "episode-viewer.modal"}}
<div class="episode-modal fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true"
    aria-label="剧集全文台词查看">
    <div class="episode-modal__overlay absolute inset-0 bg-text-main/50" data-episode-close="true"></div>

    <section class="relative z-10 w-full max-w-4xl max-h-[90vh] overflow-hidden bg-cream-bg border border-stone-200 shadow-2xl">
        {{template "episode-viewer.header" .}}
        {{template "episode-viewer.progress" .}}
        {{template "episode-viewer.body" .}}
    </section>
</div>
{{end}}

{{define "episode-viewer.header"}}
<header class="flex items-start justify-between gap-4 border-b border-stone-100 px-4 py-3">
    <div class="min-w-0">
        <p class="text-[10px] uppercase tracking-widest text-stone-400">
            {{if .EpisodeCode}}{{.EpisodeCode}}{{else}}Episode {{.EpisodeTitle}}{{end}}
        </p>
        <h2 class="text-base font-semibold text-stone-800 break-words">{{.EpisodeTitle}}</h2>
    </div>
    <button type="button" class="h-10 w-10 sm:h-8 sm:w-8 border border-stone-200 text-stone-500 hover:text-brand-accent hover:border-brand-accent"
        data-episode-close="true" aria-label="关闭">
        ×
    </button>
</header>
{{end}}

{{define "episode-viewer.progress"}}
<div class="w-full border-b border-stone-100" aria-hidden="true">
    <div class="relative h-0.5 w-full bg-stone-100">
        <div id="episode-read-progress" class="h-full bg-brand-accent transition-[width] duration-150 ease-out" style="width: 0%;"></div>
        <div id="episode-hit-markers" class="absolute inset-0 pointer-events-none"></div>
    </div>
</div>
{{end}}

{{define "episode-viewer.body"}}
<div class="episode-modal__body overflow-y-auto max-h-[calc(90vh-68px)] px-4 py-3">
    {{range .Lines}}
    {{template "episode-viewer.line" .}}
    {{end}}
</div>
{{end}}

{{define "episode-viewer.line"}}
<article class="episode-line border border-transparent px-3 py-2 mb-2 bg-cream-bg {{if .Highlighted}}episode-line--highlight{{end}}"
    {{if .Highlighted}}id="episode-highlight"{{end}}>
    <p class="text-[11px] text-stone-400 mb-1">#{{.SeqInEpisode}}</p>
    <p class="episode-line__text text-base text-stone-700 leading-snug">{{.Text}}</p>
    {{if .Character}}
    <p class="mt-1 text-xs font-semibold {{.CharacterCSS}}">{{.Character}}</p>
    {{end}}
</article>
{{end}}
