{{define "results.tmpl"}}
{{if .Items}}
{{range .Items}}
{{template "results.item" .}}
{{end}}
{{else}}
{{template "results.empty" .}}
{{end}}
{{if .HasMore}}
{{template "results.load-more" .}}
{{end}}
{{end}}

{{define "results.load-more"}}
<div hx-get="/search?q={{.Query | urlquery}}&page={{.NextPage}}" hx-trigger="revealed" hx-target="this" hx-swap="outerHTML"
    hx-indicator="#loading" class="results-pager">
    <p class="results-pager__text">继续加载更多结果...</p>
</div>
{{end}}

{{define "results.item"}}
<article class="result-card results-item group">
    <div class="results-head">
        <div class="results-meta-wrap">
            {{template "results.episode-meta" .}}
        </div>
        <div class="results-score-wrap">
            {{template "results.score-tag" .}}
        </div>
    </div>
    <p class="results-text">{{.Text}}</p>
    <div class="results-footer">
        {{template "results.character" .}}
        {{template "results.actions" .}}
    </div>
</article>
{{end}}

{{define "results.episode-meta"}}
{{if .EpisodeCode}}
<p class="results-episode-meta">{{.EpisodeCode}} · #{{.SeqInEpisode}}</p>
{{else}}
<p class="results-episode-meta">{{.EpisodeTitle}} · #{{.SeqInEpisode}}</p>
{{end}}
{{if .EpisodeTitle}}
<h3 class="results-episode-title">{{.EpisodeTitle}}</h3>
{{end}}
{{end}}

{{define "results.score-tag"}}
{{$scoreToneClass := "score-tone-base"}}
{{if gt .Score 0.75}}
{{$scoreToneClass = "score-tone-high"}}
{{else if gt .Score 0.60}}
{{$scoreToneClass = "score-tone-mid"}}
{{else if gt .Score 0.40}}
{{$scoreToneClass = "score-tone-low"}}
{{end}}
<span
    class="{{template "results.score-base-class" .}} {{$scoreToneClass}}">
    SIM: {{printf "%.4f" .Score}}
</span>
{{end}}

{{define "results.score-base-class"}}score-tag results-score{{end}}

{{define "results.character"}}
{{if .Character}}
<p class="results-character {{.CharacterCSS}}">{{.Character}}</p>
{{else}}
<span></span>
{{end}}
{{end}}

{{define "results.actions"}}
<div class="results-actions">
    {{template "results.copy-button" .}}
    {{template "results.episode-button" .}}
</div>
{{end}}

{{define "results.copy-button"}}
<button type="button"
    class="{{template "results.action-button-class" .}}"
    title="复制这段台词" aria-label="复制这段台词" data-copy-line="true" data-copy-text="{{.Text}}"
    data-copy-character="{{if .Character}}{{.Character}}{{else}}Unknown{{end}}"
    data-copy-seasoncode="{{if .EpisodeCode}}{{.EpisodeCode}}{{else}}{{.EpisodeTitle}}{{end}}">
    <svg class="copy-icon h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
    </svg>
    <svg class="check-icon h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" />
    </svg>
</button>
{{end}}

{{define "results.episode-button"}}
<button type="button"
    class="{{template "results.action-button-class" .}}"
    title="查看本集台词" aria-label="查看本集台词" hx-get="/episode?episodeID={{.EpisodeID}}&lineID={{.LineID}}"
    hx-target="#episode-viewer" hx-swap="innerHTML" hx-indicator="#episode-loading">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        class="h-4 w-4" aria-hidden="true">
        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" />
        <circle cx="12" cy="12" r="3" />
    </svg>
</button>
{{end}}

{{define "results.action-button-class"}}results-action-btn{{end}}

{{define "results.empty"}}
<div class="results-empty">
    <div class="results-empty__icon">∅</div>
    <p class="results-empty__text">No match in the void</p>
</div>
{{end}}