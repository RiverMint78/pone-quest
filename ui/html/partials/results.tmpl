{{define "results.tmpl"}}
{{range .}}
<article
    class="block relative break-inside-avoid overflow-hidden bg-white border border-stone-100 shadow-sm hover:shadow transition-shadow duration-200 group mb-6 p-4">
    <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
        <div class="min-w-0 flex-1">
            {{if .EpisodeCode}}
            <p class="text-[10px] uppercase tracking-widest text-stone-400 break-all">{{.EpisodeCode}} · #{{.SeqInEpisode}}</p>
            {{else}}
            <p class="text-[10px] uppercase tracking-widest text-stone-400 break-all">{{.EpisodeTitle}} #{{.SeqInEpisode}}</p>
            {{end}}
            {{if .EpisodeTitle}}
            <h3 class="text-sm font-semibold text-stone-700 break-all">{{.EpisodeTitle}}</h3>
            {{end}}
        </div>
        <div class="shrink-0 self-start ml-auto max-w-full flex items-center gap-2">
            {{if gt .Score 0.75}}
            <span
                class="score-tag inline-flex items-center whitespace-nowrap backdrop-blur-md bg-blue-50/90 text-blue-700 font-bold px-2 py-1 border border-blue-200/50 shadow-sm text-xs transition-transform duration-200 leading-none">
                SIM: {{printf "%.4f" .Score}}
            </span>
            {{else if gt .Score 0.60}}
            <span
                class="score-tag inline-flex items-center whitespace-nowrap backdrop-blur-md bg-emerald-50/90 text-emerald-700 font-bold px-2 py-1 border border-emerald-200/50 shadow-sm text-xs transition-transform duration-200 leading-none">
                SIM: {{printf "%.4f" .Score}}
            </span>
            {{else if gt .Score 0.40}}
            <span
                class="score-tag inline-flex items-center whitespace-nowrap backdrop-blur-md bg-amber-50/90 text-amber-700 font-bold px-2 py-1 border border-amber-200/50 shadow-sm text-xs transition-transform duration-200 leading-none">
                SIM: {{printf "%.4f" .Score}}
            </span>
            {{else}}
            <span
                class="score-tag inline-flex items-center whitespace-nowrap backdrop-blur-md bg-stone-50/90 text-stone-600 font-medium px-2 py-1 border border-stone-200/50 shadow-sm text-xs transition-transform duration-200 leading-none">
                SIM: {{printf "%.4f" .Score}}
            </span>
            {{end}}
        </div>
    </div>
    <p class="text-stone-700 text-sm leading-relaxed">{{.Text}}</p>
    <div class="flex items-center justify-between gap-2 mt-2">
        {{if .Character}}
        <p class="text-xs font-semibold {{.CharacterCSS}}">{{.Character}}</p>
        {{else}}
        <span></span>
        {{end}}
        <div class="flex items-center gap-1">
            <button type="button"
                class="shrink-0 inline-flex h-5 w-5 items-center justify-center text-stone-400 hover:text-accent transition-colors"
                title="复制这段台词" aria-label="复制这段台词" data-copy-line="true" data-copy-text="{{.Text}}"
                data-copy-character="{{if .Character}}{{.Character}}{{else}}Unknown{{end}}"
                data-copy-seasoncode="{{if .EpisodeCode}}{{.EpisodeCode}}{{else}}{{.EpisodeTitle}}{{end}}">
                <svg class="copy-icon h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                </svg>
                <svg class="check-icon h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                </svg>
            </button>
            <button type="button"
                class="shrink-0 inline-flex h-5 w-5 items-center justify-center text-stone-400 hover:text-accent transition-colors"
                title="查看本集全文台词" aria-label="查看本集全文台词"
                hx-get="/episode?episodeID={{.EpisodeID}}&lineID={{.LineID}}" hx-target="#episode-viewer"
                hx-swap="innerHTML">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    class="h-4 w-4" aria-hidden="true">
                    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" />
                    <circle cx="12" cy="12" r="3" />
                </svg>
            </button>
        </div>
    </div>
</article>
{{else}}
<div
    class="inline-block w-full py-20 text-center border border-dashed border-stone-200 break-inside-avoid bg-stone-50/50">
    <div class="mb-2 text-3xl opacity-80">∅</div>
    <p class="text-stone-400 uppercase tracking-widest text-xs">No transcript match found</p>
</div>
{{end}}
{{end}}