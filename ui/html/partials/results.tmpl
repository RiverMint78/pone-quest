{{define "results.tmpl"}}
{{range .}}
{{$path := printf "/static/images/%s" .}}

<a href="{{$path}}" target="_blank" class="result-card group p-5 block">
    <div class="aspect-square flex items-center justify-center mb-4 overflow-hidden rounded-2xl bg-stone-50">
        <img src="{{$path}}" alt="Image {{.}}"
            class="max-w-full max-h-full object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-110"
            loading="lazy">
    </div>
    <p
        class="text-[10px] text-stone-400 font-mono truncate text-center opacity-0 group-hover:opacity-100 transition-opacity">
        {{.}}
    </p>
</a>
{{else}}
<div class="col-span-full py-20 text-center">
    <div class="mb-4 text-3xl">🏜️</div>
    <p class="text-stone-300 uppercase tracking-widest text-xs">No matches in the void</p>
</div>
{{end}}
{{end}}